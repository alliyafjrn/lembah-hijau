// This is your Prisma schema file
// Versi Prisma 7: Konfigurasi URL dipindah ke prisma.config.ts

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Tiket {
  id        Int      @id @default(autoincrement())
  nama      String
  harga     Float
  stok      Int
  deskripsi String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Hewan {
  id        Int      @id @default(autoincrement())
  nama      String
  spesies   String
  habitat   String
  createdAt DateTime @default(now())
}